---
const year = new Date().getFullYear();
---
<footer>
  <div class="foot-left">© {year} Yash Barhate — Built with ❤️</div>
  <div class="foot-links">
    <a href="https://github.com/yourusername" target="_blank" rel="noopener">GitHub</a>
    <a href="https://linkedin.com/in/yourusername" target="_blank" rel="noopener">LinkedIn</a>
    <a href="https://twitter.com/yourusername" target="_blank" rel="noopener">X / Twitter</a>
    <a href="mailto:you@example.com">Email</a>
  </div>
</footer>

<style>
  footer {
    position: relative;
    z-index: 5;
    padding: 40px clamp(20px, 5vw, 64px) 48px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 20px;
    border-top: 1px solid var(--line);
    max-width: 1280px;
    margin: 0 auto;
  }
  .foot-left {
    font-family: "JetBrains Mono", monospace;
    font-size: 12px;
    color: var(--cream-dim);
    letter-spacing: 0.04em;
  }
  .foot-links {
    display: flex;
    gap: 28px;
    flex-wrap: wrap;
  }
  .foot-links a {
    font-family: "JetBrains Mono", monospace;
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--cream-dim);
    position: relative;
    padding-bottom: 2px;
    transition: color 0.3s ease;
  }
  .foot-links a::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: 0;
    width: 0%;
    height: 1px;
    background: var(--emerald);
    transition: width 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .foot-links a:hover { color: var(--emerald); }
  .foot-links a:hover::after { width: 100%; }
</style>
