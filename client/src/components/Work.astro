---
// For now the project list is static. When your server's Project model
// (see /server) is ready, swap this for a fetch, e.g.:
//
//   const res = await fetch(`${import.meta.env.PUBLIC_API_URL}/api/projects`);
//   const projects = await res.json();
//
// Astro runs this frontmatter at build time, so the page stays static
// and fast — no client-side loading spinner needed.

const projects = [
  {
    title: "Project Aurora",
    pitch: "An agentic research assistant that plans multi-step tasks and executes them autonomously across tools.",
    stack: "Next.js · Python · LangGraph",
    url: "#",
  },
  {
    title: "Project Nimbus",
    pitch: "A full-stack SaaS platform with real-time collaboration, built solo from schema to ship.",
    stack: "React · Node.js · PostgreSQL",
    url: "#",
  },
  {
    title: "Project Vertex",
    pitch: "A retrieval-augmented LLM pipeline that turns raw documents into a queryable knowledge layer.",
    stack: "FastAPI · Vector DB · OpenAI",
    url: "#",
  },
];
---
<section class="work" id="work">
  <p class="mono eyebrow" data-reveal>Selected Work</p>
  <h2 class="display" data-reveal>Things I've<br />shipped</h2>

  <div class="work-grid">
    {projects.map((p, i) => (
      <a class="work-card" href={p.url} data-reveal data-reveal-delay={Math.min(i, 3)}>
        <div class="wc-left">
          <div class="wc-title">{p.title}</div>
          <div class="wc-pitch">{p.pitch}</div>
          <div class="wc-stack">{p.stack}</div>
        </div>
        <div class="wc-arrow">↗</div>
      </a>
    ))}
  </div>
</section>

<style>
  .work {
    padding-top: 8vh;
    padding-bottom: 16vh;
    max-width: 1280px;
    margin: 0 auto;
  }
  .eyebrow { margin-bottom: 20px; }
  .work h2 {
    font-size: clamp(38px, 7vw, 88px);
    margin-bottom: 10vh;
    max-width: 900px;
  }
  .work-grid {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .work-card {
    position: relative;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
    padding: 36px 8px;
    border-top: 1px solid var(--line);
    overflow: hidden;
    transition: padding-left 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .work-grid .work-card:last-child {
    border-bottom: 1px solid var(--line);
  }
  .work-card:hover {
    padding-left: 24px;
  }
  .work-card:hover .wc-title { color: var(--emerald); }
  .work-card:hover .wc-arrow {
    transform: translate(6px, -6px);
    opacity: 1;
  }

  .wc-left { display: flex; flex-direction: column; gap: 10px; max-width: 70%; }
  .wc-title {
    font-family: "Anton", sans-serif;
    text-transform: uppercase;
    font-size: clamp(22px, 3.2vw, 38px);
    transition: color 0.3s ease;
  }
  .wc-pitch {
    color: var(--cream-dim);
    font-size: clamp(13px, 1.2vw, 16px);
    max-width: 520px;
  }
  .wc-stack {
    font-family: "JetBrains Mono", monospace;
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--emerald-dim);
    text-transform: uppercase;
  }
  .wc-arrow {
    font-size: clamp(22px, 3vw, 34px);
    color: var(--cream-dim);
    opacity: 0.5;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    flex-shrink: 0;
  }

  @media (max-width: 720px) {
    .work-card { flex-direction: column; align-items: flex-start; gap: 14px; }
    .wc-left { max-width: 100%; }
  }
</style>
