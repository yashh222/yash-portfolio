---
// 3D Rotating Object Component
// Lazy-loaded three.js animation that responds to scroll
---
<div class="three-d-container">
  <canvas id="three-d-canvas"></canvas>
</div>

<script>
  // Lazy-load the three.js animation script after browser idle
  if ('requestIdleCallback' in window) {
    requestIdleCallback(() => {
      import('../scripts/three-animation.js');
    });
  } else {
    // Fallback for browsers that don't support requestIdleCallback
    setTimeout(() => {
      import('../scripts/three-animation.js');
    }, 2000);
  }
</script>

<style>
  .three-d-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 3;
    pointer-events: none;
  }

  #three-d-canvas {
    display: block;
    width: 100%;
    height: 100%;
  }
</style>
